generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Collection {
  slug         String    @id
  name         String
  label        String
  pattern      String?
  defaultPrice Int       @default(500)
  sortOrder    Int       @default(0)
  products     Product[]
}

model Product {
  productId       String
  categorySlug    String
  collection      Collection @relation(fields: [categorySlug], references: [slug], onDelete: Cascade)
  name            String
  price           Int
  originalPrice   Int?
  discountPercent Int        @default(0)
  currency        String     @default("INR")
  description     String
  material        String     @default("Premium cotton-blend crochet yarn")
  dimensions      String     @default("18 × 14 × 8 cm (approx.)")
  care            String     @default("Spot clean only. Store in a dry place away from direct sunlight.")
  colors          Json       @default("[]")
  colorVariants   Json       @default("[]")
  sizes           Json       @default("[\"One Size\"]")
  highlights      Json       @default("[\"freeDelivery\",\"secureCheckout\",\"easyReturns\"]")
  rating          Float      @default(4.8)
  reviewCount     Int        @default(24)
  quantity        Int        @default(0)
  inStock         Boolean    @default(true)
  deliveryDays    String     @default("3–5 business days")
  media           Json       @default("[]")
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@id([categorySlug, productId])
  reviews         ProductReview[]
}

model ProductReview {
  id           String   @id @default(cuid())
  categorySlug String
  productId    String
  product      Product  @relation(fields: [categorySlug, productId], references: [categorySlug, productId], onDelete: Cascade)
  authorName   String
  rating       Int      @default(5)
  title        String?
  body         String
  createdAt    DateTime @default(now())

  @@index([categorySlug, productId, createdAt])
}

model ProductMediaFile {
  filename  String   @id
  mime      String
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id         Int    @id @default(1)
  email      String @default("hello@zrochet.com")
  phone      String @default("+91 98765 43210")
  address    String @default("123 Artisan Lane, India")
  footerText String @default("Handcrafted crochet creations made with love, patience, and a touch of magic.")
  heroImage  String @default("/images/welcome.png")
  upiId      String @default("sarathbhushan04@oksbi")
  upiPayeeName String @default("Zrochet")
  instagramUrl String @default("https://www.instagram.com/zrochet_12?igsh=MWcwOTQzZzhrajh6")
  heroEyebrow String @default("Artisan Made · One of a Kind")
  heroTitle   String @default("Handcrafted Crochet Creations")
  heroText    String @default("Discover beautifully handmade crochet bags, purses, and thoughtful gifts — each piece woven with care, warmth, and timeless charm.")
  storyImage  String @default("")
  storyTitle  String @default("The Heart of Zrochet")
  storyText   String @default("Zrochet began with a simple belief: that everyday objects deserve the warmth of human hands. What started as a quiet hobby at the kitchen table has blossomed into a boutique studio dedicated to slow, intentional craftsmanship.\n\nEvery stitch is placed with purpose. We source soft, premium yarns in earthy tones and transform them into bags, purses, and gifts that carry a piece of our story — and soon, a piece of yours.")
  storyPoint1 String @default("100% handmade, never mass-produced")
  storyPoint2 String @default("Eco-conscious yarn & packaging")
  storyPoint3 String @default("Custom orders welcome")
}

model Order {
  id            String    @id
  name          String
  email         String
  phone         String
  address       String
  items         Json
  subtotal      Int
  currency      String    @default("INR")
  status        String    @default("pending")
  paymentMethod String?   @default("upi")
  paymentProofUrl String?
  paymentProofMime String?
  paymentProofData Bytes?
  paidAt        DateTime?
  approvedAt    DateTime?
  thankYouEmailSent Boolean @default(false)
  thankYouEmailError String?
  rejectionReason String?
  rejectedAt    DateTime?
  rejectionEmailSent Boolean @default(false)
  rejectionEmailError String?
  reviewedAt    DateTime?
  shippedAt     DateTime?
  deliveryPartner String?
  trackingId    String?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())
}
