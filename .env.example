# ─── Local development (.env.local) ───
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_PASSWORD="zrochet-local"

# Railway Postgres PUBLIC URL — local dev only (not postgres.railway.internal)
# Railway → Postgres → Connect → Public Network
# Only DATABASE_PUBLIC_URL is needed locally; db:migrate reads it automatically
DATABASE_PUBLIC_URL=""

NEXT_PUBLIC_UPI_ID="yourname@oksbi"
NEXT_PUBLIC_UPI_PAYEE_NAME="Zrochet"

# Optional — thank-you email when admin approves payment
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="app-password"
# SMTP_FROM="Zrochet <your@gmail.com>"

# ─── Railway production (web service variables) ───
# DATABASE_URL=          ← reference from Postgres service
# ADMIN_PASSWORD=        ← your admin login password
# NEXT_PUBLIC_SITE_URL=  ← https://your-app.up.railway.app
# NEXT_PUBLIC_UPI_ID=
# NEXT_PUBLIC_UPI_PAYEE_NAME=Zrochet
# SMTP_* (optional)
