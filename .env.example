# ─── Local development (.env.local) ───
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_PASSWORD="zrochet-local"

# Railway Postgres PUBLIC URL — local dev only (not postgres.railway.internal)
# Railway → Postgres → Connect → Public Network
# Only DATABASE_PUBLIC_URL is needed locally; db:migrate reads it automatically
DATABASE_PUBLIC_URL=""

NEXT_PUBLIC_UPI_ID="yourname@oksbi"
NEXT_PUBLIC_UPI_PAYEE_NAME="Zrochet"

# ─── Thank-you email ───
# Localhost: Gmail SMTP (Option A)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="16-char-app-password"
# SMTP_FROM="Zrochet <your@gmail.com>"

# Railway production: SendGrid API (Option B — Gmail SMTP is BLOCKED on Railway)
# 1. sendgrid.com → API Keys → Create
# 2. Sender Authentication → Verify Single Sender (your Gmail)
# SENDGRID_API_KEY="SG.xxxxxxxx"
# SENDGRID_FROM="Zrochet <your@gmail.com>"

# Alternative: Resend API
# RESEND_API_KEY="re_xxxxxxxx"
# RESEND_FROM="Zrochet <hello@yourdomain.com>"

# ─── Railway production (web service variables) ───
# DATABASE_URL=          ← reference from Postgres service
# ADMIN_PASSWORD=
# NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_UPI_ID=
# NEXT_PUBLIC_UPI_PAYEE_NAME=Zrochet
# SENDGRID_API_KEY=      ← required for email on Railway
# SENDGRID_FROM=Zrochet <your@gmail.com>
